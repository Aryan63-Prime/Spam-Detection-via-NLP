# ========================================================
# SpamShield AI — Environment Configuration
# ========================================================
# Copy this file to .env and fill in production values.
# NEVER commit .env to version control.
# ========================================================

# ── Application ──────────────────────────────
APP_NAME=SpamShield AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ── Machine Learning ────────────────────────
ML_MAX_SEQUENCE_LENGTH=512
ML_TFIDF_MAX_FEATURES=50000
ML_USE_GPU=false
ML_USE_ONNX=true
ML_DEFAULT_MODEL=distilbert
ML_BATCH_SIZE=32
ML_EPOCHS=10
ML_LEARNING_RATE=5e-5
ML_CONFIDENCE_THRESHOLD=0.5
ML_CACHE_PREDICTIONS=true
ML_CACHE_TTL=3600

# ── PostgreSQL ───────────────────────────────
DB_POSTGRES_HOST=localhost
DB_POSTGRES_PORT=5432
DB_POSTGRES_USER=spam_user
DB_POSTGRES_PASSWORD=changeme_in_production
DB_POSTGRES_DB=spam_detection
DB_POSTGRES_POOL_SIZE=20

# ── Redis ────────────────────────────────────
DB_REDIS_HOST=localhost
DB_REDIS_PORT=6379
DB_REDIS_DB=0
DB_REDIS_PASSWORD=

# ── Security ─────────────────────────────────
SEC_JWT_SECRET_KEY=CHANGE-THIS-IN-PRODUCTION-USE-STRONG-SECRET
SEC_JWT_ALGORITHM=HS256
SEC_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
SEC_JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
SEC_RATE_LIMIT_PER_MINUTE=60
SEC_CORS_ORIGINS=["http://localhost:3000"]

# ── Monitoring ───────────────────────────────
MON_PROMETHEUS_ENABLED=true
MON_LOG_LEVEL=INFO
MON_LOG_FORMAT=json
MON_ENABLE_REQUEST_TRACING=true
